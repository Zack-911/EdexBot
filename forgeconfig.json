{
  "multiple_function_colors": true,
  "urls": [
    "github:tryforge/forgescript#dev",
    "github:tryforge/forgedb",
    "github:tryforge/forgecanvas"
  ],
  "custom_functions": [
    {
      "name": "$getRequiredXp",
      "description": "Calculates how much XP is required to level up.",
      "params": [
        {
          "name": "level",
          "description": "Current level (>= 1)",
          "required": true,
          "type": "Number"
        },
        {
          "name": "currentXp",
          "description": "XP already earned in this level",
          "required": false,
          "type": "Number"
        }
      ]
    },
    {
      "name": "$generateRankCard",
      "description": "Generates a rank card image.",
      "params": [
        {
          "name": "user",
          "description": "The user to generate the card for",
          "required": true,
          "type": "String"
        },
        {
          "name": "level",
          "description": "The level to display",
          "required": true,
          "type": "Number"
        },
        {
          "name": "xp",
          "description": "The current XP to display",
          "required": true,
          "type": "Number"
        },
        {
          "name": "req",
          "description": "The required XP to display",
          "required": true,
          "type": "Number"
        }
      ]
    },
    {
      "name": "$generateLevelUpCard",
      "description": "Generates a level-up card image.",
      "params": [
        {
          "name": "user",
          "description": "The user to generate the card for",
          "required": true,
          "type": "String"
        },
        {
          "name": "level",
          "description": "The new level reached",
          "required": true,
          "type": "Number"
        }
      ]
    }
  ]
}